// ============================================================
// ELAHMED RETAIL SUITE — Database Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// User Management
// ============================================================

model User {
  id          String    @id @default(uuid())
  username    String    @unique
  password    String    // Hashed password
  fullName    String
  role        UserRole  @default(employee)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  sales            Sale[]
  auditLogs        AuditLog[]
  stockMovements   StockMovement[]
  userRoles        UserRoleAssignment[]

  @@map("users")
}

enum UserRole {
  owner
  admin
  manager
  employee
  viewer
}

// ============================================================
// RBAC - Roles & Permissions
// ============================================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) // System roles cannot be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  permissions RolePermission[]
  users       UserRoleAssignment[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  category    String   // e.g., 'sales', 'inventory', 'reports', 'settings'
  createdAt   DateTime @default(now())

  // Relations
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  // Relations
  role       Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  assignedAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_role_assignments")
}

// ============================================================
// Products & Inventory
// ============================================================

model Product {
  id              String    @id @default(uuid())
  name            String    @db.VarChar(200)
  model           String?   @db.VarChar(100)
  barcode         String    @unique
  category        String    @db.VarChar(100)
  supplier        String?   @db.VarChar(100)
  costPrice       Decimal   @db.Decimal(12, 2)
  sellingPrice    Decimal   @db.Decimal(12, 2)
  quantity        Int       @default(0)
  minimumMarginPct Int      @default(0)
  version         Int       @default(0) // Optimistic locking
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  // Relations
  batches         ProductBatch[]
  saleItems       SaleItem[]
  stockMovements  StockMovement[]

  // Indexes for performance
  @@index([barcode])
  @@index([category])
  @@index([createdAt])
  @@index([quantity])
  @@index([deletedAt, category])
  @@map("products")
}

model ProductBatch {
  id           String    @id @default(uuid())
  productId    String
  costPrice    Decimal   @db.Decimal(12, 2)
  quantity     Int
  remainingQty Int
  version      Int       @default(0) // Optimistic locking
  purchasedAt  DateTime  @default(now())
  
  // Relations
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_batches")
}

// ============================================================
// Sales
// ============================================================

model Sale {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  date          DateTime      @default(now())
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @db.Decimal(12, 2) @default(0)
  total         Decimal       @db.Decimal(12, 2)
  totalCost     Decimal       @db.Decimal(12, 2)
  grossProfit   Decimal       @db.Decimal(12, 2)
  marginPct     Decimal       @db.Decimal(5, 2)
  paymentMethod PaymentMethod
  employeeId    String
  voidedAt      DateTime?
  voidReason    String?
  voidedBy      String?

  // Relations
  employee      User         @relation(fields: [employeeId], references: [id])
  items         SaleItem[]

  // Indexes for performance
  @@index([invoiceNumber])
  @@index([date])
  @@index([employeeId])
  @@index([voidedAt])
  @@index([date, total])
  @@map("sales")
}

model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  productId   String
  name        String
  qty         Int
  price       Decimal @db.Decimal(12, 2)
  cost        Decimal @db.Decimal(12, 2)
  lineDiscount Decimal @db.Decimal(12, 2) @default(0)

  // Relations
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

enum PaymentMethod {
  cash
  card
  split
}

// ============================================================
// Stock Movements (Audit Trail)
// ============================================================

model StockMovement {
  id              String           @id @default(uuid())
  productId       String
  type            StockMovementType
  quantityChange  Int
  previousQty     Int
  newQty          Int
  reason          String?
  referenceId     String?
  userId          String
  createdAt       DateTime         @default(now())

  // Relations
  product         Product          @relation(fields: [productId], references: [id])
  user            User             @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
  @@map("stock_movements")
}

enum StockMovementType {
  sale
  return
  manual_adjustment
  import
  correction
}

// ============================================================
// Audit Log (Immutable - INSERT ONLY)
// ============================================================
// NOTE: Audit logs are immutable by design. No UPDATE or DELETE operations
// should be performed on this table. Enforce at application level and
// consider database triggers for additional protection.

model AuditLog {
  id          String    @id @default(uuid())
  userId      String
  action      String
  entityType  String
  entityId    String?
  description String?   // Human-readable description
  ipAddress   String?   // Client IP address
  userAgent   String?   // Browser/client info
  before      Json?
  after       Json?
  createdAt   DateTime  @default(now())

  // Relations
  user        User      @relation(fields: [userId], references: [id])

  // Indexes for fast querying
  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// Categories
// ============================================================

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  nameAr      String?
  type        CategoryType
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("categories")
}

enum CategoryType {
  mobile
  computer
  device
  accessory
  used
  car
  other
}

// ============================================================
// Customers (CRM)
// ============================================================

model Customer {
  id          String    @id @default(uuid())
  name        String
  phone       String?
  email       String?
  address     String?
  notes       String?
  totalPurchases Decimal  @db.Decimal(12, 2) @default(0)
  visitCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  sales       Sale[]

  @@index([phone])
  @@index([email])
  @@map("customers")
}

// ============================================================
// Suppliers
// ============================================================

model Supplier {
  id          String    @id @default(uuid())
  name        String
  phone       String?
  email       String?
  address     String?
  notes       String?
  balance    Decimal   @db.Decimal(12, 2) @default(0)
  active     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  products    Product[]
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id          String            @id @default(uuid())
  orderNumber String            @unique
  supplierId  String
  status      PurchaseOrderStatus @default(pending)
  total       Decimal           @db.Decimal(12, 2)
  paid        Decimal           @db.Decimal(12, 2) @default(0)
  notes       String?
  orderDate   DateTime          @default(now())
  expectedDate DateTime?
  receivedDate DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  supplier    Supplier          @relation(fields: [supplierId], references: [id])
  items      PurchaseOrderItem[]

  @@index([supplierId])
  @@index([orderNumber])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(uuid())
  purchaseOrderId String
  productName     String
  quantity        Int
  unitCost        Decimal @db.Decimal(12, 2)
  receivedQty     Int     @default(0)

  // Relations
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("purchase_order_items")
}

enum PurchaseOrderStatus {
  pending
  ordered
  partial
  received
  cancelled
}

// ============================================================
// Branches (Multi-branch support)
// ============================================================

model Branch {
  id          String    @id @default(uuid())
  name        String
  nameAr      String?
  address     String?
  phone       String?
  isActive   Boolean   @default(true)
  isMain     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  sales       Sale[]
  products    Product[]
  users      User[]

  @@map("branches")
}

// ============================================================
// Settings (Tax, etc.)
// ============================================================

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  type        String   @default("string") // string, number, boolean, json
  description String?
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

// ============================================================
// Background Jobs (BullMQ Job Tracking)
// ============================================================

model BackgroundJob {
  id          String        @id @default(uuid())
  name        String        // Job name from BullMQ
  data        Json?         // Job data
  opts        Json?         // Job options
  progress    Int           @default(0) // 0-100
  status      JobStatus     @default(pending)
  result      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  scheduledAt DateTime?
  attempts    Int           @default(0)
  maxAttempts Int           @default(3)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([name, status])
  @@index([scheduledAt])
  @@map("background_jobs")
}

enum JobStatus {
  pending
  delayed
  waiting
  active
  completed
  failed
  stuck
}
