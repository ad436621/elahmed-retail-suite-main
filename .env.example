# ============================================================
# ElAhmed Retail Suite — Environment Variables
# ============================================================

# Application
NODE_ENV=development
FRONTEND_PORT=80
BACKEND_PORT=3000

# Database
DB_USER=elahmed
DB_PASSWORD=your_secure_password
DB_NAME=elahmed_retail
DB_PORT=5432
DB_HOST=localhost

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_super_secure_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost

# Sentry
SENTRY_DSN=
SENTRY_SECRET_KEY=

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Prometheus
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
SENTRY_PORT=9000
